{
  "name": "ares-agent",
  "version": "0.1.0",
  "private": true,
  "description": "ARES-AGENT: Solana audit platform with LangGraph + OpenRouter + Crystalline cognitive memory",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "audit": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "ingest:solsec": "tsx src/scripts/ingest-solsec.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.2.3",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@langchain/langgraph-cua": "^1.0.2",
    "@langchain/openai": "^1.5.5",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.47.10",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "neo4j-driver": "^5.27.0",
    "pg": "^8.13.1",
    "uuid": "^11.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^4.1.10"
  }
}
