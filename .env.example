# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_REFERRER=ares-agent

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_COMMITMENT=confirmed
# Optional Helius RPC — overrides SOLANA_RPC_URL for on-chain reads when set.
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=xxxxxxxx

# Postgres (LangGraph checkpoint)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ares
POSTGRES_USER=ares
POSTGRES_PASSWORD=ares_dev_password
POSTGRES_SSL=false

# Supabase (hybrid keyword + vector retrieval) — OPTIONAL.
# When unset, recall falls back to Crystalline-only. Apply
# db/supabase/0001_hybrid_search.sql before ingesting.
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx

# Neo4j (graph expansion + relationship reranking) — OPTIONAL.
# docker compose brings up a local instance (user is always "neo4j").
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=ares_dev_password

# Embeddings (OpenAI-compatible endpoint) — OPTIONAL.
# Required for semantic search + ingestion; recall degrades to lexical without it.
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_API_KEY=sk-xxxxxxxx
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIM=1536

# Seed knowledge base (used by `npm run ingest:solsec`).
SOLSEC_REPO_URL=https://github.com/sannykim/solsec.git

# NOTE: Semgrep is an optional local binary used by the static analyzer.
# Install it (pipx install semgrep) to enable source-code scanning.

# Computer Use Agent (CUA) — browser-driving investigation analyzer — OPTIONAL,
# opt-in (set CUA_ENABLED=true or pass --cua). Requires BOTH keys below.
# IMPORTANT: the CUA model (OpenAI computer-use-preview) is invoked directly,
# NOT via OpenRouter, so it needs its own OPENAI_API_KEY.
# OPENAI_API_KEY=sk-xxxxxxxx
# SCRAPYBARA_API_KEY=scrapy-xxxxxxxx
CUA_ENABLED=false
CUA_ENVIRONMENT=web
CUA_TIMEOUT_HOURS=1
CUA_RECURSION_LIMIT=100

# ARES runtime
ARES_MAX_ITERATIONS=12
ARES_THREAD_ID=ares-default
ARES_LOG_LEVEL=info

# Billing / monetization (credits) — OPTIONAL, opt-in. With BILLING_ENABLED
# unset, ARES does no metering or settlement. When on, each audit is metered on
# LLM token usage, marked up with a guaranteed margin, and charged in credits.
# BILLING_ENABLED=false
# One credit = this many USD (default $0.01 → 100 credits = $1).
# BILLING_CREDIT_USD=0.01
# Revenue markup over raw provider cost (1.3 = 30% margin).
# BILLING_MARKUP=1.3
# Guaranteed minimum gross margin; the markup is floored at 1 + this so a run
# can never bill below cost even if BILLING_MARKUP is misconfigured.
# BILLING_MIN_MARGIN_PCT=0.2
# Minimum credits billed per audit (covers fixed overhead on tiny runs).
# BILLING_MIN_CHARGE_CREDITS=1
# Prepaid system-credit allotment (a plan/subscription balance).
# BILLING_PLAN_CREDITS=0
# Allow pay-as-you-go on-demand overflow once prepaid credits are spent.
# BILLING_ONDEMAND_ENABLED=false
# Optional cap on total on-demand credits.
# BILLING_ONDEMAND_LIMIT_CREDITS=
# Durable account persistence. When set, prepaid balance and on-demand spend are
# loaded/saved from this JSON file so spend accumulates across runs. Unset → the
# account resets to BILLING_PLAN_CREDITS every run (no persistence).
# BILLING_ACCOUNT_STORE_PATH=
# Machine Payments Protocol (MPP, https://mpp.dev) settlement for on-demand
# usage. Unset → hermetic local settlement (no network). MPP_PAYER_ID identifies
# the payer presented to MPP.
# MPP_ENDPOINT=
# MPP_PAYER_ID=ares-agent
# When MPP_ENDPOINT is set but the real HTTP-402 client is not wired, refuse to
# settle on-demand charges locally unless this explicitly opts in. Default false.
# MPP_ALLOW_LOCAL_FALLBACK=false
