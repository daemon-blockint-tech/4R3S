# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_REFERRER=ares-agent

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_COMMITMENT=confirmed
# Optional Helius RPC — overrides SOLANA_RPC_URL for on-chain reads when set.
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=xxxxxxxx

# Postgres (LangGraph checkpoint)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ares
POSTGRES_USER=ares
POSTGRES_PASSWORD=ares_dev_password
POSTGRES_SSL=false

# Supabase (hybrid keyword + vector retrieval) — OPTIONAL.
# When unset, recall falls back to Crystalline-only. Apply
# db/supabase/0001_hybrid_search.sql before ingesting.
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx

# Neo4j (graph expansion + relationship reranking) — OPTIONAL.
# docker compose brings up a local instance (user is always "neo4j").
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=ares_dev_password

# Embeddings (OpenAI-compatible endpoint) — OPTIONAL.
# Required for semantic search + ingestion; recall degrades to lexical without it.
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_API_KEY=sk-xxxxxxxx
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIM=1536

# Seed knowledge base (used by `npm run ingest:solsec`).
SOLSEC_REPO_URL=https://github.com/sannykim/solsec.git

# NOTE: Semgrep is an optional local binary used by the static analyzer.
# Install it (pipx install semgrep) to enable source-code scanning.

# Computer Use Agent (CUA) — browser-driving investigation analyzer — OPTIONAL,
# opt-in (set CUA_ENABLED=true or pass --cua). Requires BOTH keys below.
# IMPORTANT: the CUA model (OpenAI computer-use-preview) is invoked directly,
# NOT via OpenRouter, so it needs its own OPENAI_API_KEY.
# OPENAI_API_KEY=sk-xxxxxxxx
# SCRAPYBARA_API_KEY=scrapy-xxxxxxxx
CUA_ENABLED=false
CUA_ENVIRONMENT=web
CUA_TIMEOUT_HOURS=1
CUA_RECURSION_LIMIT=100

# ARES runtime
ARES_MAX_ITERATIONS=12
ARES_THREAD_ID=ares-default
ARES_LOG_LEVEL=info
